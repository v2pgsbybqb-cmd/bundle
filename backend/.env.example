# ── Snippe (https://snippe.sh/dashboard) ─────────────────────────────────────
# API key from your Snippe dashboard
SNIPPE_API_KEY=your_snippe_api_key_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://bundle-ls5z.onrender.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
