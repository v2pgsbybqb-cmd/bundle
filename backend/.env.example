# ── Flutterwave (https://dashboard.flutterwave.com) ──────────────────────────
# Secret key from your Flutterwave dashboard
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X

# Secret hash you set in Flutterwave dashboard → Settings → Webhooks
FLW_WEBHOOK_SECRET=your_webhook_secret_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://unlockvip-frontend.onrender.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
